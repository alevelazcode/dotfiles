{
  "show_completions_on_input": true,
  "format_on_save": "on",
  "formatter": "language_server",
  "minimap": {
    "show": "always",
    "thumb": "always",
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": [
          "bypassPermissions"
        ]
      },
      "type": "registry",
      "default_config_options": {
        "model": "opus",
      },
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "enabled_in_text_threads": false,
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": false,
    "quick_actions": true,
  },
  "vim": {
    "use_smartcase_find": true,
    "use_system_clipboard": "always",
    "use_multiline_find": true,
  },
  "relative_line_numbers": "enabled",
  "tab_size": 2,
  "preferred_line_length": 80,
  "indent_guides": {
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "fixed",
    "background_coloring": "indent_aware",
  },
  "always_treat_brackets_as_autoclosed": true,
  "inlay_hints": {
    "enabled": true,
  },
  "tasks": {
    "prefer_lsp": true,
  },
  "colorize_brackets": true,
  "notification_panel": {
    "button": false,
  },
  "terminal": {
    "button": false,
  },
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": true,
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
    "commit_message_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
  },
  "git_panel": {
    "sort_by_path": true,
    "tree_view": true,
    "dock": "right",
  },
  "project_panel": {
    "entry_spacing": "comfortable",
    "dock": "right",
    "default_width": 280,
    "hide_root": true,
    "starts_open": false,
    "git_status": true,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "experimental.theme_overrides": {
    "syntax": {
      "keyword": {
        "font_style": "italic",
      },
      "operator": {
        "font_style": "italic",
      },
      "function": {
        "font_style": "italic",
      },
      "comment": {
        "font_style": "italic",
      },
      "comment.doc": {
        "font_style": "italic",
      },
    },
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "never",
    },
    "dock": "right",
    "button": false,
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "cursor_shape": "block",
  "cursor_blink": false,
  "buffer_font_family": "DankMono Nerd Font Mono",
  "buffer_font_features": {
    "calt": true,
  },
  "title_bar": {
    "show_branch_icon": true,
  },
  "use_system_window_tabs": false,
  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.5,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "vim_mode": true,
  "buffer_line_height": {
    "custom": 2
  },
  "current_line_highlight": "gutter",
  "icon_theme": {
    "mode": "light",
    "light": "FantastIcons Icon Theme",
    "dark": "Catppuccin Mocha",
  },
  "ui_font_size": 18,
  "buffer_font_size": 18.0,
  "agent_buffer_font_size": 18,
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Monokai Vibrant Amped"
  },
  "scrollbar": {
    "show": "never",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
    },
  },
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enabled": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": false,
  },
  "centered_layout": {
    "left_padding": 0.1,
    "right_padding": 0.1,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "show_commit_summary": true,
    },
  },
  "languages": {
    "Python": {
      "language_servers": [
        "pylsp",
        "ruff"
      ],
    },
    "TypeScript": {
      "language_servers": [
        "typescript-language-server",
        "prettier",
        "!eslint"
      ],
    },
    "TSX": {
      "language_servers": [
        "typescript-language-server",
        "prettier",
        "!eslint"
      ],
    },
    "JavaScript": {
      "language_servers": [
        "typescript-language-server",
        "prettier",
        "!eslint"
      ],
    },
    "HTML": {
      "language_servers": [
        "vscode-html-language-server",
        "prettier",
        "!eslint"
      ],
    },
  },
  "lsp": {
    "pylsp": {
      "settings": {
        "pylsp.plugins.pylsp_django": {
          "enabled": true,
        },
        "pylsp.plugins.jedi_completion": {
          "include_params": true,
        },
      },
    },
  },
  "tabs": {
    "file_icons": true,
  },
}
