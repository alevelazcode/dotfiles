{
  "[csharp]": {
    "editor.maxTokenizationLineLength": 2500
  },
  "editor.semanticHighlighting.enabled": true,
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true
  },
  "[rust]": {
    "editor.formatOnSave": true
  },
  "[vue]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "explicit"
    }
  },
  "console-ninja.fontSize": 13,
  "css.format.spaceAroundSelectorSeparator": true,
  "dart.flutterSdkPath": "/Users/alejandrovelazco/development/flutter",
  "editor.bracketPairColorization.enabled": true,
  
  // MOVIDO A CONFIGURACIONES ESPECÍFICAS POR LENGUAJE
  // "editor.codeActionsOnSave": {
  //   "source.fixAll.eslint": "explicit",
  //   "source.organizeImports": "explicit",
  //   "source.addMissingImports": "explicit"
  // },
  
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "explicit"
    }
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "explicit"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit",
      "source.organizeImports": "explicit",
      "source.addMissingImports": "explicit"
    }
  },
  
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorSurroundingLines": 8,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "'Dank Mono', 'VictorMono Nerd Font', 'CaskaydiaCove Nerd Font', 'JetBrainsMono Nerd Font','Mononoki Nerd Font' , Menlo ",
  "editor.fontLigatures": "'calt', 'ss01'",
  "editor.fontSize": 13,
  "editor.fontWeight": "400",
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "editor.glyphMargin": false,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.inlineSuggest.enabled": true,
  "editor.lineHeight": 2.2,
  "editor.linkedEditing": true,
  "editor.overviewRulerBorder": false,
  "editor.renderWhitespace": "selection",
  "editor.scrollbar.vertical": "hidden",
  "editor.smoothScrolling": true,
  "editor.stickyScroll.enabled": true,
  "editor.tabCompletion": "on",
  "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
  "editor.rulers": [88],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.formatOnSaveTimeout": 3000,
  "editor.wordWrap": "on",
  "editor.dragAndDrop": false,
  "editor.dropIntoEditor.enabled": false,
  "editor.foldingImportsByDefault": true,
  
  // Emmet
  "emmet.triggerExpansionOnTab": true,
  "errorLens.excludeBySource": ["eslint(no-undef)", "ts(2786)"],
  "eslint.validate": [
    "vue",
    "javascript",
    "typescript",
    "javascriptreact",
    "typescriptreact"
  ],
  "eslint.useFlatConfig": true,
  "eslint.experimental.useFlatConfig": true,
  
  "explorer.compactFolders": false,
  "explorer.confirmDelete": false,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.ignoreRebaseWarning": true,
  "git.openRepositoryInParentFolders": "always",
  "files.insertFinalNewline": false,
  "files.trimFinalNewlines": true,
  "files.autoGuessEncoding": true,
  "files.autoSaveWhenNoErrors": true,
  "files.autoSaveWorkspaceFilesOnly": true,
  
  "github.copilot.enable": {
    "*": true,
    "markdown": false,
    "plaintext": false,
    "scminput": false
  },
  "github.copilot.editor.enableAutoCompletions": true,
  
  "glassit.alpha": 235,
  "gopls": {
    "formatting.gofumpt": true
  },
  
  "jupyter.interactiveWindow.textEditor.executeSelection": true,
  "notebook.output.scrolling": true,
  "notebook.output.textLineLimit": 100,
  "notebook.output.fontFamily": "'CaskaydiaCove Nerd Font' , 'Mononoki Nerd Font'   , Menlo ",
  
  "oneDarkPro.bold": true,
  "oneDarkPro.editorTheme": "One Dark Pro Darker",
  "oneDarkPro.vivid": true,
  
  "php-cs-fixer.config": ".php-cs-fixer.php",
  "php-cs-fixer.executablePath": "${workspaceFolder}/vendor/bin/php-cs-fixer",
  "phpfmt.exclude": ["ReindentComments", "StripNewlineWithinClassBody"],
  "phpfmt.passes": [
    "PSR2KeywordsLowerCase",
    "PSR2LnAfterNamespace",
    "PSR2CurlyOpenNextLine",
    "PSR2ModifierVisibilityStaticOrder",
    "PSR2SingleEmptyLineAndStripClosingTag",
    "ReindentSwitchBlocks"
  ],
  "phpfmt.psr2": true,
  
  // ========== CONFIGURACIÓN PYTHON CORREGIDA ==========
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      // Orden crítico: organizeImports primero, luego fixAll
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    },
    "editor.rulers": [88],
    "editor.tabSize": 4
  },
  
  // Servidor nativo de Ruff (configuración mínima)
  "ruff.nativeServer": "on",
  "ruff.enable": true,
  "ruff.fixAll": false,
  "ruff.organizeImports": false,
  
  // Python - desactivar todos los demás formateadores/linters
  "python.languageServer": "None",
  "python.formatting.provider": "none",
  "python.linting.enabled": false,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": false,
  "python.linting.banditEnabled": false,
  "python.linting.mypyEnabled": false,
  "python.sortImports.provider": "none",
  
  // Python - configuración de análisis
  "python.analysis.autoSearchPath": true,
  "python.analysis.extraPaths": [
    "src/lib",
    "all-stubs/cpython_patch",
    "all-stubs/mpy_1_13-nightly_frozen/esp32/GENERIC",
    "all-stubs/esp32_1_13_0-103"
  ],
  "python.autoComplete.extraPaths": [
    "src/lib",
    "all-stubs/cpython_patch",
    "all-stubs/mpy_1_13-nightly_frozen/esp32/GENERIC",
    "all-stubs/esp32_1_13_0-103"
  ],
  
  // MyPy opcional (si lo necesitas)
  "mypy.runUsingDmypy": true,
  
  // ========== FIN CONFIGURACIÓN PYTHON ==========
  
  "security.workspace.trust.untrustedFiles": "open",
  "security.promptForLocalFileProtocolHandling": false,
  
  "symbols.hidesExplorerArrows": false,
  "synthwave84.brightness": 0.1,
  "synthwave84.disableGlow": false,
  
  "tailwindCSS.emmetCompletions": true,
  
  "terminal.external.linuxExec": "kitty",
  "terminal.external.osxExec": "iTerm2.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.env.linux": {},
  "terminal.integrated.env.osx": {},
  "terminal.integrated.env.windows": {},
  "terminal.integrated.fontSize": 12,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font' , 'Mononoki Nerd Font'   , Menlo ",
  "terminal.integrated.inheritEnv": false,
  
  "typescript.updateImportsOnFileMove.enabled": "always",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  
  // Vim
  "vim.easymotion": true,
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-f>": false,
    "<C-p>": false,
    "<C-s>": false,
    "<C-z>": false
  },
  "vim.highlightedyank.color": "#a9dc7660",
  "vim.highlightedyank.duration": 250,
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.leader": "<space>",
  "vim.normalModeKeyBindings": [
    {
      "before": ["g", "q"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["g", "p", "d"],
      "commands": ["editor.action.peekDefinition"]
    },
    {
      "before": ["g", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.view.explorer"]
    },
    {
      "before": ["g", "h"],
      "commands": ["editor.action.showDefinitionPreviewHover"]
    },
    {
      "before": ["g", "r"],
      "commands": ["editor.action.referenceSearch.trigger"]
    },
    {
      "before": ["g", "t"],
      "commands": ["editor.action.goToTypeDefinition"]
    },
    {
      "before": ["g", "p", "t"],
      "commands": ["editor.action.peekTypeDefinition"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["<leader>", "c"],
      "commands": ["editor.action.commentLine"]
    },
    {
      "before": ["<leader>", "f"],
      "commands": ["revealInExplorer"]
    }
  ],
  "vim.smartRelativeLine": false,
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindings": [
    {
      "before": ["<leader>", "c"],
      "commands": ["editor.action.commentLine", "extension.vim_escape"]
    }
  ],
  
  // Workbench
  "workbench.colorTheme": "Gruvbox Material Dark",
  "workbench.iconTheme": "bearded-icons",
  "workbench.colorCustomizations": {},
  "workbench.editor.showTabs": "single",
  "workbench.editor.enablePreview": false,
  "workbench.layoutControl.enabled": false,
  "workbench.preferredDarkColorTheme": "Moonlight II Italic",
  "workbench.preferredHighContrastColorTheme": "Moonlight II Italic",
  "workbench.preferredHighContrastLightColorTheme": "Moonlight II Italic",
  "workbench.preferredLightColorTheme": "Moonlight II Italic",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.statusBar.visible": false,
  "workbench.tree.indent": 20,
  "workbench.sideBar.location": "right",
  "workbench.activityBar.location": "top",
  
  "window.commandCenter": false,
  "window.zoomLevel": 1,
  
  // Extensiones específicas
  "gruvboxMaterial.italicKeywords": true,
  "errorLens.fontFamily": "'CaskaydiaCove Nerd Font' , 'Mononoki Nerd Font'   , Menlo ",
  "editor.codeLensFontFamily": "'CaskaydiaCove Nerd Font' , 'Mononoki Nerd Font'   , Menlo ",
  "markdown.preview.fontFamily": "'CaskaydiaCove Nerd Font' , 'Mononoki Nerd Font'   , Menlo ",
  "codesnap.shutterAction": "copy",
  "markdown.extension.print.theme": "dark",
  "markdown-preview-enhanced.previewTheme": "one-dark.css",
  "markdown-preview-enhanced.revealjsTheme": "night.css",
  "markdown-preview-enhanced.mermaidTheme": "dark",
  "react-native-tools.networkInspector.consoleLogsColorTheme": "Dark",
  "cSpell.userWords": ["Fastify", "pnpx"],
  "javascript.updateImportsOnFileMove.enabled": "always",
  "prettier.endOfLine": "auto",
  "vue.server.hybridMode": true,
  "prisma.showPrismaDataPlatformNotification": false,
  "makefile.configureOnOpen": true,
  "console-ninja.featureSet": "Community",
  "gitlens.ai.model": "openai:o1-preview",
  
  // Windsurf
  "windsurf.autocompleteSpeed": "default",
  "windsurf.autoExecutionPolicy": "off",
  "windsurf.chatFontSize": "default",
  "windsurf.rememberLastModelSelection": false,
  "windsurf.explainAndFixInCurrentConversation": false,
  "windsurf.openRecentConversation": false,
  "windsurf.enableTabToJump": false,
  
  "remote.extensionKind": {
    "adpyke.codesnap": ["ui"]
  }
}
